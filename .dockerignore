# Virtual environment — never include this
venv/
.venv/
env/

# Environment variables — never include secrets
.env

# Raw data files — too large for image
data/raw/

# Trained model files — regenerated by pipeline
models/*.pkl
models/*.npz

# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Git files
.git/
.gitignore

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# SQL dumps
*.sql.gz
feedback_intelligence.sql

# Jupyter notebooks
*.ipynb
.ipynb_checkpoints/

# Test files
tests/
test_*.py